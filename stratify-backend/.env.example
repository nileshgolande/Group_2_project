# Live stock quotes (yfinance / Yahoo). List & detail refresh stale rows automatically.
STOCK_LIVE_MAX_STALE_SECONDS=120
STOCK_LIVE_REQUEST_DELAY_SECONDS=0.15
STOCK_LIVE_LIST_MAX_REFRESH=30
STOCK_DETAIL_CACHE_SECONDS=45
# Celery beat: how often to refresh all stock prices (needs worker + beat + Redis)
STOCK_CELERY_REFRESH_MINUTES=5
